<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Thème principal de l'application -->
    <style name="Theme.GestionDepensesESMT" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Couleurs principales -->
        <item name="colorPrimary">@color/gold_primary</item>
        <item name="colorSecondary">@color/gold_primary</item>

        <!-- Couleur des textes dans les champs de saisie -->
        <item name="android:editTextColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>

        <!-- LIAISON VERS LE NOUVEAU THEME DU CALENDRIER -->
        <item name="materialCalendarTheme">@style/MonCalendrierTheme</item>
    </style>

    <!-- LE THEME MAGIQUE POUR LE CALENDRIER -->
    <style name="MonCalendrierTheme" parent="ThemeOverlay.MaterialComponents.MaterialCalendar">
        <item name="colorSurface">@color/card_bg</item> <!-- Fond du calendrier -->
        <item name="colorPrimary">@color/gold_primary</item> <!-- Couleur de sélection et boutons OK/Annuler -->
        <item name="colorOnPrimary">@color/charcoal_dark</item> <!-- Texte sur l'or (ex: 2026) -->
        <item name="colorOnSurface">@color/text_primary</item> <!-- Jours du mois (Blanc) -->
    </style>

    <style name="Theme.KINGGestionDepenses" parent="Theme.GestionDepensesESMT" />
</resources>
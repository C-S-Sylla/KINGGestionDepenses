<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg"> <!-- CORRECTION: app_bg s'adapte au thème clair/sombre -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TITRE -->
        <TextView
            android:id="@+id/txtTitrePage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nouvelle Dépense"
            android:textColor="@color/gold_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="25dp" />

        <!-- 1. MONTANT -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Montant (FCFA) *"
            app:hintTextColor="@color/gold_primary"
            android:textColorHint="@color/gray_text"
            app:boxStrokeColor="@color/gold_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editMontant"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textColorHint="@color/gray_text"
                android:textColor="@color/text_primary" /> <!-- CORRECTION: text_primary s'adapte au thème -->
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 2. CATÉGORIE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Catégorie *"
            android:textColor="@color/gray_text"
            android:layout_marginTop="15dp"/>

        <Spinner
            android:id="@+id/spinnerCategorie"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:backgroundTint="@color/gold_primary"
            android:entries="@array/categories_defaut" />

        <!-- 3. RUBRIQUE (Sous-catégorie optionnelle) -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Rubrique"
            app:hintTextColor="@color/gold_primary"
            android:textColorHint="@color/gray_text"
            app:boxStrokeColor="@color/gold_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editRubrique"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColorHint="@color/gray_text"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 4. DATE -->
        <Button
            android:id="@+id/btnDate"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="15dp"
            android:text="Date : Aujourd'hui"
            android:textColor="@color/text_primary"
            app:strokeColor="@color/gray_text" />

        <!-- 5. MOYEN DE PAIEMENT -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Moyen de paiement"
            android:textColor="@color/gray_text"
            android:layout_marginTop="15dp"/>

        <Spinner
            android:id="@+id/spinnerPaiement"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:backgroundTint="@color/gold_primary"
            android:entries="@array/moyens_paiement" />

        <!-- 6. DESCRIPTION -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Note / Description"
            app:hintTextColor="@color/gold_primary"
            android:textColorHint="@color/gray_text"
            app:boxStrokeColor="@color/gold_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:lines="3"
                android:textColorHint="@color/gray_text"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- BOUTON ENREGISTRER -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="ENREGISTRER LA DÉPENSE"
            android:backgroundTint="@color/gold_primary"
            android:textColor="@color/app_bg"
            android:textStyle="bold"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="20dp" />

    </LinearLayout>
</ScrollView>